{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=AluminaDetectionDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Mqtt": {
    "Broker": "localhost",
    "Port": "1883",
    "Username": "",
    "Password": "",
    "MaxBurst": "20",
    "RefillRatePerSecond": "10"
  },
  "Processing": {
    "DataIntervalSeconds": "15",
    "FeatureWindowMinutes": "5"
  },
  "ApplicationInsights": {
    "ConnectionString": "",
    "EnableRequestTrackingTelemetryModule": true,
    "EnableDependencyTrackingTelemetryModule": true,
    "EnableEventCounterCollectionModule": true,
    "EnablePerformanceCounterCollectionModule": true
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System.Net.Http": "Warning"
      }
    }
  },
  "Svr": {
    "C": 1.0,
    "Epsilon": 0.1,
    "Gamma": 0.5,
    "MaxTrainingSamples": 2000,
    "MatchingTimeToleranceMinutes": 2.0,
    "MinTrainingSamples": 5,
    "OutputMin": 1.5,
    "OutputMax": 4.0,
    "SmoTolerance": 0.001,
    "SmoMaxPasses": 100,
    "SupportVectorThreshold": 1e-8,
    "FeatureNames": [
      "MeanVoltage", "StdVoltage", "Skewness", "Kurtosis",
      "FrequencyPeak", "NoisePower",
      "DominantFrequencyAmplitude", "SpectralEnergyRatio",
      "HighFrequencyNoiseRatio", "SpectralCentroid", "SpectralBandwidth"
    ],
    "Heuristic": {
      "Base": 3.0,
      "StdVoltageFactor": -0.5,
      "StdVoltageScale": 0.1,
      "SkewnessFactor": -0.3,
      "SkewnessScale": 0.5,
      "HighFreqNoiseFactor": -0.4,
      "SpectralEnergyFactor": 0.2
    }
  },
  "Rf": {
    "TreeCount": 10,
    "MaxDepth": 5,
    "MinSamplesLeaf": 5,
    "MaxTrainingSamples": 5000,
    "MinTrainingSamples": 10,
    "RandomSeed": 42,
    "EffectTimeWindowMinutes": 3.0,
    "MinAccuracyForProduction": 0.70,
    "AccuracyDropThreshold": 0.15,
    "EvaluationWindowSize": 50,
    "TrainingIntervalHours": 2.0,
    "FeatureNames": [
      "NoisePower", "StdVoltage", "FrequencyPeak", "MeanVoltage",
      "DominantFrequencyAmplitude", "HighFrequencyNoiseRatio",
      "SpectralEnergyRatio", "SpectralBandwidth"
    ],
    "Heuristic": {
      "NoisePowerWeight": 2.0,
      "NoisePowerOffset": 0.5,
      "StdVoltageWeight": 1.5,
      "StdVoltageOffset": 0.3,
      "FrequencyPeakWeight": 0.5,
      "HighFreqNoiseWeight": 3.0
    }
  },
  "Alarm": {
    "ConcentrationAlarmThreshold": 1.5,
    "ConcentrationAlarmDurationMinutes": 5,
    "ConcentrationAlarmDedupMinutes": 10,
    "AnodeEffectProbabilityThreshold": 0.80,
    "AnodeEffectAlarmDedupMinutes": 5,
    "FeedingTriggerConcentration": 1.8,
    "FeedingTargetConcentration": 2.5,
    "FeedingMinAmountKg": 1.0,
    "FeedingCooldownMinutes": 5,
    "EffectQuenchPrimaryFeedKg": 3.0,
    "EffectQuenchSecondaryFeedKg": 2.0
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
